        Cache: - _evict_if_needed()
        Cache: + get(url str, allow_stale bool) Optional[CachedResponse]
        Cache: + set(url str, response CachedResponse)
        Cache: + delete(url str)
        Cache: + clear()
        Cache: + get_all_keys() List[str]
        Cache: + get_stats() Dict[str, Any]
        
